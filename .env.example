# Copy this file to .env and fill in values before starting the server.
# Do NOT commit .env to source control.

PORT=4000
NODE_ENV=development

JWT_SECRET=dev-secret-key

DB_PATH=./dev.db

# AES-256 encryption key for SQLCipher at-rest encryption.
# Leave blank in development (node:sqlite runtime ignores it).
# REQUIRED in production with a SQLCipher-enabled runtime — loss of this key
# means permanent data loss. Rotate with: PRAGMA rekey = '<new-key>'
DB_ENCRYPTION_KEY=

# Front-end URL (used for CORS in production)
FRONTEND_URL=https://your-amplify-domain.amplifyapp.com

# SAML SSO (Azure AD)
SAML_IDP_METADATA_URL=https://login.microsoftonline.com/<tenant-id>/federationmetadata/2007-06/federationmetadata.xml
SAML_SP_ENTITY_ID=https://your-domain/saml
SAML_SP_ACS_URL=https://your-domain/auth/saml/callback

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=https://your-app.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:4000/auth/cognito/callback
