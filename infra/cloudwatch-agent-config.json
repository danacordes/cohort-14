{
  "agent": {
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/home/ec2-user/.pm2/logs/cohort14-out.log",
            "log_group_name": "/cohort14/backend",
            "log_stream_name": "{instance_id}/stdout",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "multi_line_start_pattern": "\\{",
            "encoding": "utf-8"
          },
          {
            "file_path": "/home/ec2-user/.pm2/logs/cohort14-error.log",
            "log_group_name": "/cohort14/backend",
            "log_stream_name": "{instance_id}/stderr",
            "timestamp_format": "%Y-%m-%dT%H:%M:%S",
            "encoding": "utf-8"
          }
        ]
      }
    },
    "log_stream_name": "{instance_id}/default",
    "force_flush_interval": 15
  }
}
